    {
      "parameters": {
        "jsCode": "const rawText = ($input.item.json.text || \"\");\n\nconst cleaned = rawText\n  .replace(/```json\\s*/gi, \"\")\n  .replace(/```\\s*/gi, \"\")\n  .trim();\n\nlet tool = \"fallback\";\nlet inputOriginal = cleaned;\n\ntry {\n  const data = JSON.parse(cleaned);\n  tool = data.tool || \"fallback\";\n  inputOriginal = data.input || rawText;\n} catch (e) {\n  const lower = cleaned.toLowerCase();\n  if (lower.includes(\"queja\") || lower.includes(\"cae\") || lower.includes(\"no funciona\") || lower.includes(\"error\") || lower.includes(\"no puedo\") || lower.includes(\"perdi\") || lower.includes(\"perdí\")) tool = \"queja_urgente\";\n  else if (lower.includes(\"sugerencia\") || lower.includes(\"estaria\") || lower.includes(\"estaría\") || lower.includes(\"podrian\") || lower.includes(\"podrían\") || lower.includes(\"me gustaria\")) tool = \"sugerencia_producto\";\n  else if (lower.includes(\"spam\") || lower.includes(\"troll\") || lower.includes(\"odio\") || lower.includes(\"mierda\")) tool = \"spam_o_troll\";\n}\n\nconst comentarioOriginal = $input.item.json[\"Comentario\"] \n  || $('Google Sheets Trigger').item.json[\"Comentario\"] \n  || inputOriginal;\n\nreturn {\n  tool: tool,\n  input: comentarioOriginal\n};"
      },
